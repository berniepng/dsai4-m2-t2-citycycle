# .env.example
# ==============
# Copy this to .env and fill in your values.
# NEVER commit .env to Git — it is blocked by .gitignore.
#
#   cp .env.example .env
#   # then edit .env with your real values

# ── Google Cloud Platform ─────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id

# Path to GCP service account JSON key (for prod/CI).
# In local dev, use `gcloud auth application-default login` instead.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/keyfile.json

# ── BigQuery datasets ─────────────────────────────────────────────
BQ_RAW_DATASET=citycycle_raw        # where Meltano / load_mock.py writes raw data
BQ_DEV_DATASET=citycycle_dev        # dbt dev target
BQ_PROD_DATASET=citycycle_marts     # dbt prod target

# ── Meltano ───────────────────────────────────────────────────────
MELTANO_ENVIRONMENT=dev             # dev | prod

# ── Dashboard ─────────────────────────────────────────────────────
USE_MOCK_DATA=1                     # 1 = mock CSV (dev), 0 = live BQ (prod)

# ── Alerting (optional) ───────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ── Dagster ───────────────────────────────────────────────────────
# DAGSTER_HOME=/path/to/dagster_home   # where Dagster stores run history
